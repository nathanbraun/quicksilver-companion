---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'An enhanced reading companion for Neal Stephenson\'s Quicksilver' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title} | Quicksilver Reading Companion</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#faf8f4" />
  <link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <script is:inline>
    // Apply saved theme immediately to prevent flash
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
  </script>
  <script defer src="/stats/script.js" data-website-id="8641f255-cc5f-4428-adcf-53141ade9195"></script>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <div class="site-title-row">
        <a href="/" class="site-title"><img src="/logo.png" alt="" class="site-logo" />Quicksilver Reading Companion</a>
        <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
          <span class="theme-icon">☀️</span>
        </button>
      </div>
      <nav class="site-nav">
        <a href="/before-you-read">Before You Read</a>
        <div class="nav-dropdown">
          <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">Books <span class="dropdown-arrow">&#9662;</span></button>
          <div class="nav-dropdown-menu">
            <a href="/book/1">Book 1: Quicksilver</a>
            <a href="/book/2">Book 2: Vagabonds</a>
            <a href="/book/3">Book 3: Odalisque</a>
          </div>
        </div>
        <a href="/topics">Topics & Characters</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>
  <main class="main-content">
    <slot />
  </main>
  <pwa-install
    manifest-url="/manifest.json"
    name="Quicksilver Reading Companion"
    description="Page-by-page historical annotations for Neal Stephenson's Quicksilver"
    icon="/pwa-512x512.png"
  ></pwa-install>
  <script>
    import '@khmyznikov/pwa-install';
  </script>
  <script>
    document.addEventListener('click', (e) => {
      const toggle = (e.target as HTMLElement).closest('.nav-dropdown-toggle');
      const dropdown = (e.target as HTMLElement).closest('.nav-dropdown');
      document.querySelectorAll('.nav-dropdown.open').forEach(el => {
        if (el !== dropdown) el.classList.remove('open');
      });
      if (toggle) {
        const parent = toggle.closest('.nav-dropdown')!;
        parent.classList.toggle('open');
        toggle.setAttribute('aria-expanded', parent.classList.contains('open').toString());
      }
    });

    // Theme toggle
    const themeBtn = document.querySelector('.theme-toggle')!;
    const themeIcon = themeBtn.querySelector('.theme-icon')!;

    function updateIcon() {
      const isDark = document.documentElement.classList.contains('dark');
      themeIcon.textContent = isDark ? '☀️' : '🌙';
      themeBtn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }

    updateIcon();

    themeBtn.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      const isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcon();
    });
  </script>
</body>
</html>
