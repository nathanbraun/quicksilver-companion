---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'An enhanced reading companion for Neal Stephenson\'s Quicksilver' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title} | Quicksilver Reading Companion</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#faf8f4" />
  <link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
  </script>
</head>
<body>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-title"><img src="/logo.png" alt="" class="site-logo" />Quicksilver Reading Companion</a>
      <nav class="site-nav">
        <a href="/before-you-read">Before You Read</a>
        <a href="/book/1">Book 1: Quicksilver</a>
        <a href="/book/2">Book 2: Vagabonds</a>
        <a href="/book/3">Book 3: Odalisque</a>
        <a href="/topics">Topics & Characters</a>
      </nav>
    </div>
  </header>
  <main class="main-content">
    <slot />
  </main>
</body>
</html>
