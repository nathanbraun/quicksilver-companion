---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';

const changelogRaw = fs.readFileSync('src/data/changelog.md', 'utf-8');

// Parse markdown into [{date, items}]
const changelog: {date: string, items: string[]}[] = [];
for (const line of changelogRaw.split('\n')) {
  const dateMatch = line.match(/^## (\d{4}-\d{2}-\d{2})/);
  if (dateMatch) {
    changelog.push({ date: dateMatch[1], items: [] });
  } else if (line.startsWith('- ') && changelog.length > 0) {
    changelog[changelog.length - 1].items.push(line.slice(2));
  }
}
---

<BaseLayout title="About">
  <div class="content-narrow">
    <h1>About This Site</h1>
    <p>
      The Quicksilver Reading Companion is a page-by-page guide to Neal Stephenson's
      <em>Quicksilver</em>, the first volume of The Baroque Cycle. It provides historical
      and scientific context for the people, places, events, and ideas woven through the novel.
    </p>

    <h2>What's here</h2>
    <p>
      Each chapter has an annotation page with notes keyed to specific passages. These explain
      the real history behind what you're reading — who the people were, what actually happened,
      how the science worked. There are also topic pages that go deeper on
      recurring subjects like the Royal Society, the slave trade, or Leibniz's calculus.
    </p>
    <p>
      Three "Before You Read" primers provide historical background for each book
      without spoiling the plot.
    </p>

    <h2>Where it comes from</h2>
    <p>
      This site builds on the <a href="https://quicksilver.wiki">Quicksilver Metaweb</a>,
      a community wiki started in 2003 when the novel was first published.
      Neal Stephenson contributed annotations himself, and other readers added their own.
      That original wiki material has been filtered, edited, and merged with new annotations
      covering all three books.
    </p>

    <h2>How it was made</h2>
    <p>
      The annotations were generated with the help of large language models (Gemini and Claude),
      then reviewed and edited by hand. The site is built with
      <a href="https://astro.build">Astro</a> and hosted on Netlify.
    </p>

    <h2>Page numbers</h2>
    <p>
      All page references are to the US hardcover first edition (2003). If you're reading
      a different edition, page numbers may not match exactly, but chapter boundaries should
      line up.
    </p>

    <h2>Contact</h2>
    <p>
      Built by <a href="https://nathanbraun.com">Nathan Braun</a>.
      Found an error or have a suggestion? Open an issue on
      <a href="https://github.com/nathanbraun/quicksilver-wiki">GitHub</a>.
    </p>

    <h2>Offline reading</h2>
    <p>
      Save all pages to your device for offline reading — useful for planes, subways,
      or anywhere without a connection. It's all text, so it won't take up much space.
    </p>
    <div id="offline-controls">
      <div id="offline-status"></div>
      <button id="offline-download" class="btn">Save for offline</button>
      <button id="offline-clear" class="btn btn-secondary" style="display:none">Clear saved pages</button>
      <div id="offline-progress" style="display:none">
        <div class="progress-bar"><div class="progress-fill"></div></div>
        <span class="progress-text"></span>
      </div>
    </div>

    <h2 id="changelog">Changelog</h2>
    <dl class="changelog">
      {changelog.map(entry => (
        <>
          <dt>{entry.date}</dt>
          {entry.items.map(item => <dd>{item}</dd>)}
        </>
      ))}
    </dl>
  </div>

  <style>
    #offline-controls {
      margin: 1rem 0 1.5rem;
    }
    #offline-status {
      margin-bottom: 0.5rem;
      color: var(--color-text-muted);
      font-size: 0.9rem;
    }
    .btn {
      display: inline-block;
      padding: 0.5rem 1.2rem;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      background: var(--color-accent);
      color: #fff;
      font-family: var(--font-body);
      font-size: 0.9rem;
      cursor: pointer;
      margin-right: 0.5rem;
    }
    .btn:hover {
      opacity: 0.9;
    }
    .btn-secondary {
      background: transparent;
      color: var(--color-text-muted);
    }
    .btn-secondary:hover {
      background: var(--color-border);
    }
    .progress-bar {
      width: 100%;
      max-width: 20rem;
      height: 6px;
      background: var(--color-border);
      border-radius: 3px;
      margin: 0.75rem 0 0.25rem;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      width: 0%;
      background: var(--color-accent);
      border-radius: 3px;
      transition: width 0.2s;
    }
    .progress-text {
      font-size: 0.85rem;
      color: var(--color-text-muted);
    }
  </style>

  <script>
    const downloadBtn = document.getElementById('offline-download')!;
    const clearBtn = document.getElementById('offline-clear')! as HTMLElement;
    const statusEl = document.getElementById('offline-status')!;
    const progressEl = document.getElementById('offline-progress')! as HTMLElement;
    const progressFill = document.querySelector('.progress-fill')! as HTMLElement;
    const progressText = document.querySelector('.progress-text')!;

    let allPages: string[] = [];

    async function init() {
      if (!('serviceWorker' in navigator)) {
        statusEl.textContent = 'Offline saving is not supported in this browser.';
        downloadBtn.style.display = 'none';
        return;
      }

      try {
        const res = await fetch('/all-pages.json');
        allPages = await res.json();
      } catch {
        statusEl.textContent = 'Could not load page list.';
        return;
      }

      // Check current cache status
      const reg = await navigator.serviceWorker.ready;
      reg.active?.postMessage({ type: 'CHECK_CACHE', urls: allPages });
    }

    navigator.serviceWorker?.addEventListener('message', (event) => {
      const data = event.data;

      if (data.type === 'CACHE_STATUS') {
        if (data.cached >= data.total) {
          statusEl.textContent = `All ${data.total} pages saved for offline reading.`;
          downloadBtn.textContent = 'Re-download all';
          clearBtn.style.display = 'inline-block';
        } else if (data.cached > 0) {
          statusEl.textContent = `${data.cached} of ${data.total} pages saved.`;
          clearBtn.style.display = 'inline-block';
        } else {
          statusEl.textContent = `${data.total} pages available to save.`;
        }
      }

      if (data.type === 'CACHE_PROGRESS') {
        const pct = Math.round((data.done / data.total) * 100);
        progressFill.style.width = pct + '%';
        progressText.textContent = `${data.done} of ${data.total} pages`;
      }

      if (data.type === 'CACHE_COMPLETE') {
        progressEl.style.display = 'none';
        downloadBtn.disabled = false;
        downloadBtn.textContent = 'Re-download all';
        statusEl.textContent = `All ${allPages.length} pages saved for offline reading.`;
        clearBtn.style.display = 'inline-block';
      }

      if (data.type === 'CACHE_CLEARED') {
        statusEl.textContent = `${allPages.length} pages available to save.`;
        downloadBtn.textContent = 'Save for offline';
        clearBtn.style.display = 'none';
      }
    });

    downloadBtn.addEventListener('click', async () => {
      const reg = await navigator.serviceWorker.ready;
      downloadBtn.disabled = true;
      downloadBtn.textContent = 'Saving…';
      progressEl.style.display = 'block';
      progressFill.style.width = '0%';
      progressText.textContent = '0 of ' + allPages.length + ' pages';
      reg.active?.postMessage({ type: 'CACHE_ALL', urls: allPages });
    });

    clearBtn.addEventListener('click', async () => {
      const reg = await navigator.serviceWorker.ready;
      reg.active?.postMessage({ type: 'CLEAR_CACHE' });
    });

    init();
  </script>
</BaseLayout>
