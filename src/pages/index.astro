---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getChaptersByBook } from '../utils/chapters';

const annotations = await getCollection('annotations');
const annotatedPages = [...new Set(annotations.map(a => a.data.page))].sort((a, b) => a - b);

// Count total notes (bolded-quote entries) across all annotations
const totalNotes = annotations.reduce((sum, a) => {
  return sum + (a.body?.match(/\*\*["\u201c]/g) || []).length;
}, 0);

const books = [
  { num: 1, title: 'Quicksilver', desc: 'Daniel Waterhouse, Isaac Newton, and the founding of the Royal Society.' },
  { num: 2, title: 'King of the Vagabonds', desc: 'Jack Shaftoe and Eliza cross Europe from Vienna to Amsterdam.' },
  { num: 3, title: 'Odalisque', desc: 'Eliza at Versailles, Daniel in London, and the Glorious Revolution.' },
];
---

<BaseLayout title="Home">
  <div class="content-narrow">
    <h1>Quicksilver Reading Companion</h1>
    <p>
      An enhanced guide to Neal Stephenson's <em>Quicksilver</em>, the first volume of The Baroque Cycle.
      Chapter-by-chapter annotations, character profiles, and historical context to deepen your reading.
    </p>
    <p style="font-size: 0.9rem; color: var(--color-text-muted);">
      Built from the original <a href="https://quicksilver.wiki">Quicksilver Metaweb</a> wiki (2003),
      enhanced with additional historical and literary context.
    </p>

    <h2>I'm on page...</h2>
    <div class="page-navigator">
      <input type="number" id="page-input" min="1" max="930" placeholder="e.g. 150" />
      <button id="go-btn">Go</button>
    </div>
    <p style="font-size: 0.85rem; color: var(--color-text-muted);">
      {annotatedPages.length} chapters annotated with {totalNotes} notes.
      Page numbers refer to the US hardcover first edition.
    </p>

    <h2>The Three Books</h2>
    <div class="book-sections">
      {books.map(book => {
        const bookChapters = getChaptersByBook(book.num);
        const bookAnnotations = annotations.filter(a => a.data.book === book.num);
        const bookNotes = bookAnnotations.reduce((sum, a) => {
          return sum + (a.body?.match(/\*\*["\u201c]/g) || []).length;
        }, 0);
        return (
          <div class={`book-section book-${book.num}`}>
            <h3><a href={`/book/${book.num}`}>{book.title}</a></h3>
            <p>{book.desc}</p>
            <p style="font-size: 0.85rem;">
              {bookChapters.length} chapters &middot; {bookAnnotations.length} annotated &middot; {bookNotes} notes
            </p>
          </div>
        );
      })}
    </div>
  </div>

  <script define:vars={{ annotatedPages }}>
    function goToPage() {
      const input = document.getElementById('page-input');
      const page = parseInt(input.value);
      if (!page || page < 1) return;

      // Find the chapter that contains this page (largest chapter start page <= entered page)
      let targetPage = null;
      for (let i = annotatedPages.length - 1; i >= 0; i--) {
        if (annotatedPages[i] <= page) {
          targetPage = annotatedPages[i];
          break;
        }
      }

      if (targetPage) {
        window.location.href = `/page/${targetPage}`;
      } else {
        // Page is before any annotations — go to first chapter
        window.location.href = `/page/${annotatedPages[0]}`;
      }
    }
    document.getElementById('go-btn')?.addEventListener('click', goToPage);
    document.getElementById('page-input')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') goToPage();
    });
  </script>
</BaseLayout>
